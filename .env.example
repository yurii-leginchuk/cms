# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=cms_user
POSTGRES_PASSWORD=cms_password
POSTGRES_DB=cms_db

# Backend
NODE_ENV=development
PORT=3000
JWT_SECRET=change_me_in_production

# Secret encryption (AES-256-GCM) for stored R2 / Cloudflare credentials.
# REQUIRED before you can save R2 credentials for image optimization.
# Generate one with:  openssl rand -hex 32
ENCRYPTION_KEY=

# Public origin of THIS CMS backend, reachable from the client WordPress sites.
# Used to build the image-optimization webhook callback URL the plugin calls
# when a new image is uploaded. e.g. https://cms.youragency.com
CMS_PUBLIC_URL=http://localhost:3000

# MCP <-> backend shared API key (ApiKeyGuard).
# Leave EMPTY to disable the gate (open backend — local-dev default).
# When set, every /api route requires this key via `Authorization: Bearer <key>`
# or `X-API-Key: <key>`. The MCP server must run with CMS_API_KEY set to the
# same value, and the frontend with VITE_CMS_API_KEY set to the same value.
MCP_API_KEY=

# Frontend
VITE_API_URL=http://localhost:3000
# Must match MCP_API_KEY above when the gate is enabled (else the UI gets 401s).
VITE_CMS_API_KEY=